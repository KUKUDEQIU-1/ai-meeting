{
  "name": "ai-meeting",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix server && npm install --prefix client",
    "dev": "concurrently \"npm run dev --prefix server\" \"npm run dev --prefix client\"",
    "start": "npm run start --prefix server",
    "build": "npm run build --prefix client",
    "test": "node server/scripts/test-getnote-import.js",
    "debug:feishu-create-table": "node server/scripts/debug-feishu-create-table.ts",
    "debug:feishu-permission": "node server/scripts/debug-feishu-bitable-permission.ts",
    "debug:getnote-one": "node server/scripts/debug-getnote-one.ts",
    "sync:getnote": "node server/scripts/sync-getnote.ts",
    "daily:getnote": "node server/scripts/daily-getnote.ts",
    "worker:getnote": "node server/scripts/worker-getnote.ts",
    "debug:getnote-sync": "node server/scripts/test-getnote-import.js",
    "debug:feishu-row-height": "node server/scripts/debug-feishu-row-height.ts",
    "fix:meeting-table-fields": "node server/scripts/fix-meeting-table-fields.ts",
    "fix:meeting-table-schema": "node server/scripts/fix-meeting-table-schema.ts",
    "check:meeting-table-schemas": "node server/scripts/check-meeting-table-schemas.ts",
    "list:meeting-tables": "node server/scripts/list-meeting-tables.ts",
    "backfill:task-history": "node server/scripts/backfill-task-history.ts",
    "list:task-history": "node server/scripts/list-task-history.ts",
    "list:task-progress": "node server/scripts/list-task-progress.ts",
    "list:discarded-items": "node server/scripts/list-discarded-items.ts",
    "latest:sync-summary": "node server/scripts/latest-sync-summary.ts",
    "delete:meeting-table": "node server/scripts/delete-meeting-table.ts"
